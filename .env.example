# Public URL for this app. Required when registering the built-in echo service.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Payer key used by Agent402 to pay & call / verify x402 endpoints.
# Must be a funded EVM private key (0x + 64 hex). Used SERVER-SIDE ONLY — it is
# never sent to the browser. WARNING: on Base mainnet this wallet spends real USDC.
X402_EVM_PRIVATE_KEY=

# Receiver wallet for the built-in /api/x402/echo payable endpoint.
X402_PAY_TO=

# Coinbase CDP credentials used by the built-in Base mainnet x402 facilitator.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Price for /api/x402/echo.
X402_ECHO_PRICE=$0.01

# Optional: GitHub token to raise rate limits for the discovery crawler
# (POST /api/crawl, GitHub adapter). Unauthenticated works but is rate-limited.
GITHUB_TOKEN=

# Optional: shared secret to protect the scheduled uptime prober.
# When set, POST /api/health requires `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=
